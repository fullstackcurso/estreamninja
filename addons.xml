<?xml version='1.0' encoding='UTF-8' standalone='yes'?>
<addons>
<addon id="plugin.video.streamninja" name="StreamNinja" version="1.0.0" provider-name="RubenSDFA1laberot">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests"/>
    <import addon="inputstream.adaptive" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="kodi.context.item">
    <menu id="kodi.core.main">
      <item library="context_play.py">
        <label>Abrir con StreamNinja</label>
        <visible>Addon.SettingBool(plugin.video.streamninja,enable_context_play) + !ListItem.IsFolder</visible>
      </item>
      <item library="context_copy.py">
        <label>Copiar a StreamNinja</label>
        <visible>Addon.SettingBool(plugin.video.streamninja,enable_context_copy) + !ListItem.IsFolder</visible>
      </item>
    </menu>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es">Reproductor de URLs</summary>
    <description lang="es">StreamNinja permite enviar URLs a Kodi desde un móvil o PC mediante una web local efímera, o bien recibirlas directamente desde otros addons. Soporta Dailymotion, YouTube, AceStream, Torrents y casi cualquier enlace de vídeo.</description>
    <platform>all</platform>
    <license>GPL-2.0-or-later</license>
    <assets>
      <icon>icon.jpg</icon>
    </assets>
  </extension>
</addon>

<addon id="repository.streamninja" name="StreamNinja Repository" version="1.0.0" provider-name="RubenSDFA1laberot">
    <extension point="xbmc.addon.repository" name="StreamNinja Repository">
        <dir>
            <info compressed="false">https://fullstackcurso.github.io/estreamninja/addons.xml</info>
            <checksum>https://fullstackcurso.github.io/estreamninja/addons.xml.md5</checksum>
            <datadir zip="true">https://fullstackcurso.github.io/estreamninja/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Repositorio de StreamNinja</summary>
        <description lang="es">Repositorio oficial para instalar y actualizar el addon StreamNinja.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
</addons>
